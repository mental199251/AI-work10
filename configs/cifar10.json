  "num_workers": 4,
  "label_dropout": 0.0,
  "grad_clip": 1.0,
  "amp": true,
  "download": false,
  "sample_every": 1,
  "checkpoint_every": 5,
  "preview_sampling_steps": 50,
  "preview_images": 16,
  "log_every": 20,
  "device": "auto",
  "seed": 42
}
